<ProfilScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        # En-tête
        BoxLayout:
            size_hint_y: 0.1
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#9b59b6')
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Button:
                text: '<'
                size_hint_x: 0.15
                font_size: dp(20)
                bold: True
                background_color: 0.6, 0.4, 0.8, 1
                on_press: root.manager.current = 'dashboard'
            
            Label:
                text: 'MON PROFIL'
                font_size: dp(18)
                bold: True
                color: 1, 1, 1, 1
            
            Label:
                size_hint_x: 0.15
        
        # Contenu
        ScrollView:
            size_hint_y: 0.8
            do_scroll_x: False
            
            BoxLayout:
                orientation: 'vertical'
                padding: dp(20)
                spacing: dp(15)
                size_hint_y: None
                height: self.minimum_height
                
                # Avatar
                Label:
                    text: '👤'
                    font_size: dp(80)
                    size_hint_y: None
                    height: dp(120)
                    color: 1, 1, 1, 1
                
                # Nom complet
                Label:
                    id: full_name
                    text: ''
                    font_size: dp(22)
                    bold: True
                    size_hint_y: None
                    height: dp(40)
                    color: 1, 1, 1, 1
                
                # Rôle
                Label:
                    id: role_label
                    text: ''
                    font_size: dp(16)
                    size_hint_y: None
                    height: dp(30)
                
                # Séparateur
                Widget:
                    size_hint_y: None
                    height: dp(20)
                
                # Détails dans un cadre
                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(15)
                    spacing: dp(10)
                    size_hint_y: None
                    height: self.minimum_height
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#34495e')
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(10)]
                    
                    Label:
                        id: username_detail
                        text: ''
                        font_size: dp(14)
                        size_hint_y: None
                        height: dp(30)
                        color: 1, 1, 1, 1
                    
                    Label:
                        id: email_detail
                        text: ''
                        font_size: dp(14)
                        size_hint_y: None
                        height: dp(30)
                        color: 1, 1, 1, 1
                    
                    Label:
                        id: id_detail
                        text: ''
                        font_size: dp(14)
                        size_hint_y: None
                        height: dp(30)
                        color: 1, 1, 1, 1
                
                # Espace
                Widget:
                    size_hint_y: None
                    height: dp(30)
                
                # Bouton déconnexion
                Button:
                    id: logout_btn
                    text: '🔓 SE DÉCONNECTER'
                    size_hint_y: None
                    height: dp(50)
                    background_color: 0.8, 0.2, 0.2, 1
                    font_size: dp(16)
                    bold: True
                    on_press: root.logout()
        
        # Barre de navigation
        BoxLayout:
            size_hint_y: 0.1
            spacing: dp(2)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#34495e')
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            Button:
                text: 'ACCUEIL'
                font_size: dp(14)
                bold: True
                background_color: 0.2, 0.6, 0.9, 1
                on_press: root.manager.current = 'dashboard'
            
            Button:
                text: 'VENTES'
                font_size: dp(14)
                bold: True
                background_color: 0.3, 0.7, 0.4, 1
                on_press: root.manager.current = 'ventes'
            
            Button:
                text: 'PRODUITS'
                font_size: dp(14)
                bold: True
                background_color: 0.9, 0.5, 0.2, 1
                on_press: root.manager.current = 'produits'